    throw 'click tracking disabled due to missing CSRF token (FAQ)';
  }

  const faqQuestions = document.querySelectorAll('.js-faq-question');
  const numberedFaqs = [{"answer":"The study identified 58 fungal species, predominantly 50 anamorphic fungi, with significant potential for detergent degradation.","question":"What fungi species were effective in degrading household detergents?","number":1},{"answer":"Increasing detergent concentrations negatively impacted the biomass of the dominant fungal species identified in wastewater.","question":"How were fungal populations affected by detergent concentrations?","number":2},{"answer":"Detergent degradation was evaluated through optical density measurements before and after fungal inoculation in wastewater samples.","question":"What methodology was used to assess detergent degradation by fungi?","number":3},{"answer":"Fungi can play a crucial role in bioremediation, potentially removing harmful surfactants from domestic wastewater.","question":"What are the implications of fungi on domestic wastewater treatment?","number":4},{"answer":"Synthetic detergents have been found to significantly disrupt aquatic ecosystems, affecting microbial populations essential for nutrient cycling.","question":"How do synthetic detergents impact aquatic ecosystems according to this study?","number":5}];
