window.userInChina = "false";
window.facebookLoginDisabled = 'true';</script><script defer="" src="https://accounts.google.com/gsi/client"></script><div class="ungated-variant"><div class="ungated-variant__container"><div class="ungated-variant__left-panel"><div class="ungated-work-card-panel"><div class="ungated-work-card-panel__scrollable-content"><div class="ungated-work-card-panel__padded-content"><div class="ungated-work-card--container js-loswp-work-card" id="loswp-work-card"><div class="ungated-work-card--work-information"><div class="ungated-work-card--title-row"><h1 class="ungated-work-card--work-title ds2-5-heading-sans-serif-sm" id="title">Effect of Household detergents (Surfactants)Degraded through aquatic fungi</h1><button aria-controls="work-metadata-details" aria-expanded="false" class="ungated-work-card--info-badge js-info-badge-toggle js-loswp-info-badge" type="button"><span class="material-symbols-outlined" style="font-size: 16px" translate="no">info</span><p class="ungated-work-card--info-badge-text ds2-5-body-sm">Info</p><span class="ungated-work-card--info-badge-arrow"><span class="material-symbols-outlined ungated-work-card--info-badge-arrow-down" style="font-size: 16px" translate="no">keyboard_arrow_down</span><span class="material-symbols-outlined ungated-work-card--info-badge-arrow-up" style="font-size: 16px" translate="no">keyboard_arrow_up</span></span></button></div><div class="ungated-work-card--authors"><div class="ungated-work-card--author-avatars"><div class="ungated-work-card--author-avatar" data-tooltip-id="author-tooltip-10123107-0" id="author-avatar-10123107-0"><img alt="Dr Amiy Chaturvedi" src="https://0.academia-photos.com/4924081/6679153/7546286/tiny_dr_amiy.chaturvedi.jpg" /></div><div anchor="author-avatar-10123107-0" class="ungated-work-card--author-tooltip" id="author-tooltip-10123107-0" popover="manual">Dr Amiy Chaturvedi</div></div><div class="ungated-work-card--author-names"><a class="ungated-work-card--author-link ds2-5-body-md ds2-5-body-link js-tc