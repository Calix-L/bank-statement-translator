# Bank Statement Translator Configuration
# Copy this file to .env and fill in your API keys

# ===================
# Translation API
# ===================
# Get your API key from: https://open.bigmodel.cn/
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_MODEL=glm-4-flash
ZHIPU_API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions

# ===================
# OCR API
# ===================
# Get your token from Baidu PaddleOCR: https://aistudio.baidu.com/
OCR_TOKEN=your_ocr_token_here
OCR_API_URL=https://paddleocr.aistudio-app.com/api/v2/ocr/jobs

# ===================
# Runtime Limits
# ===================
MAX_FILE_SIZE_MB=10
MAX_PDF_PAGES=30
TARGET_LANGUAGE=English
REQUEST_TIMEOUT_SEC=30
RETRY_TIMES=2
MAX_RETRIES=3

# ===================
# Performance
# ===================
# Enable caching for faster repeated processing
ENABLE_CACHE=true
CACHE_DIR=.cache
BATCH_SIZE=10

# ===================
# Output Settings
# ===================
# Include original Chinese data in Excel output
INCLUDE_RAW_SHEET=true
# Output format: xlsx, csv, json
OUTPUT_FORMAT=xlsx

# ===================
# Logging
# ===================
# DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Leave empty for console only
LOG_FILE=
